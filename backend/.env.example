# Smart Finance Core - Environment Variables

# Application
APP_NAME="Smart Finance Core"
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql+asyncpg://smartfinance:smartfinance123@localhost:5432/smartfinance
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# Two-Factor Authentication
ENABLE_2FA=true
OTP_VALIDITY_SECONDS=300

# AI Model Settings
AI_MODEL_PATH=./ml/models
AI_CONFIDENCE_THRESHOLD=0.85
AI_AUTO_CONFIRM_THRESHOLD=0.95
AI_REVIEW_REQUIRED_THRESHOLD=0.60

# External APIs (Optional)
CARD_API_KEY=
CARD_API_SECRET=
TAX_INVOICE_API_KEY=
BANK_API_KEY=

# OCR Settings
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# AWS S3 (for archiving - Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=smartfinance-archive

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Douzone Integration (Optional)
DOUZONE_API_URL=
DOUZONE_API_KEY=
